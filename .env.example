# ── Backend environment ──────────────────────────────────────────────
# Copy to .env and fill in. NEVER commit the real .env.

NODE_ENV=development
PORT=3000
API_PREFIX=api

# Frontend origin allowed by CORS (comma-separated for multiple)
FRONTEND_ORIGIN=http://localhost:5173

# Supabase — Settings → API
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# SERVICE ROLE key. Server-only secret — bypasses RLS. NEVER ship to the browser.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# ── Email notifications (Resend) — OPTIONAL ──────────────────────────
# Leave RESEND_API_KEY / ADMIN_EMAIL blank to DISABLE emails (app still boots).
# API key: https://resend.com → API Keys
RESEND_API_KEY=
# Recipient for "new order" notifications (the shop admin's inbox).
ADMIN_EMAIL=
# From address. Default = Resend sandbox onboarding@resend.dev, which only
# delivers to your own Resend account email. For production, verify a domain on
# Resend and use it here, e.g. "Camping Rental <no-reply@yourdomain.com>".
MAIL_FROM=Camping Rental <onboarding@resend.dev>
